{
  "name": "tfhe-wasm-par",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "./build.sh",
    "build:dev": "MODE=development DEVTOOL=source-map ./build.sh",
    "start": "npm run build && npm run server:multithreaded",
    "start:dev": "npm run build:dev && npm run server:multithreaded",
    "start:cross-origin": "npm run build && npm run server:cross-origin",
    "start:cross-origin:dev": "npm run build:dev && npm run server:cross-origin",
    "server:multithreaded": "serve --config ../serve.multithreaded.json dist/",
    "server:cross-origin": "serve --config ../serve.cross-origin.json dist/",
    "format": "prettier . --write",
    "check-format": "prettier . --check"
  },
  "author": "",
  "license": "BSD-3-Clause-Clear",
  "devDependencies": {
    "prettier": "^3.3.3",
    "serve": "^14.2.5",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "comlink": "^4.4.1",
    "wasm-feature-detect": "^1.6.2"
  }
}
